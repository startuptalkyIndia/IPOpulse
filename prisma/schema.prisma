generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Admin / Auth
// ============================================================

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin") // admin | superadmin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admin_users")
}

model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  name         String?
  banned       Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  watchlist    WatchlistItem[]
  applications IpoApplication[]
  comments     Comment[]
  commentVotes CommentVote[]
  ipoPolls     IpoPoll[]
  advisor      Advisor?

  @@map("users")
}

model Comment {
  id          Int       @id @default(autoincrement())
  userId      String    @map("user_id")
  targetType  String    @map("target_type") // ipo | stock
  targetSlug  String    @map("target_slug")
  body        String    @db.Text
  parentId    Int?      @map("parent_id")
  score       Int       @default(0)
  hidden      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]     @relation("CommentReplies")
  votes   CommentVote[]

  @@index([targetType, targetSlug, createdAt])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

model CommentVote {
  id        Int     @id @default(autoincrement())
  userId    String  @map("user_id")
  commentId Int     @map("comment_id")
  value     Int     // -1 or +1
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("comment_votes")
}

model IpoPoll {
  id        Int      @id @default(autoincrement())
  ipoId     Int      @map("ipo_id")
  userId    String   @map("user_id")
  vote      String   // subscribe | avoid | watching
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipo  Ipo  @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@unique([userId, ipoId])
  @@index([ipoId])
  @@map("ipo_polls")
}

model WatchlistItem {
  id         Int      @id @default(autoincrement())
  userId     String   @map("user_id")
  type       String   // ipo | stock
  targetSlug String   @map("target_slug")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, targetSlug])
  @@index([userId, type])
  @@map("watchlist_items")
}

model IpoApplication {
  id                Int      @id @default(autoincrement())
  userId            String   @map("user_id")
  ipoId             Int      @map("ipo_id")
  applicationNumber String?  @map("application_number")
  lotsApplied       Int?     @map("lots_applied")
  category          String?  // retail | hni | employee
  applyDate         DateTime? @map("apply_date")
  status            String   @default("applied") // applied | allotted | not_allotted | sold | held
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipo  Ipo  @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@unique([userId, ipoId])
  @@index([userId])
  @@map("ipo_applications")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@map("sessions")
}

// ============================================================
// Company Master
// ============================================================

model Company {
  id          Int      @id @default(autoincrement())
  bseCode     String?  @unique @map("bse_code")
  nseSymbol   String?  @unique @map("nse_symbol")
  isin        String?  @unique
  name        String
  slug        String   @unique
  sector      String?
  industry    String?
  marketCap   Decimal? @map("market_cap") @db.Decimal(20, 2)
  listedOn    DateTime? @map("listed_on")
  isSme       Boolean  @default(false) @map("is_sme")
  active      Boolean  @default(true)

  // Fundamental ratios (optional — populated from BSE/NSE filings as available)
  peRatio          Decimal? @map("pe_ratio") @db.Decimal(10, 2)
  pbRatio          Decimal? @map("pb_ratio") @db.Decimal(10, 2)
  roePercent       Decimal? @map("roe_pct") @db.Decimal(8, 2)
  debtToEquity     Decimal? @map("debt_to_equity") @db.Decimal(8, 2)
  dividendYield    Decimal? @map("dividend_yield") @db.Decimal(6, 2)
  eps              Decimal? @db.Decimal(12, 2)
  bookValue        Decimal? @map("book_value") @db.Decimal(12, 2)
  faceValue        Decimal? @map("face_value") @db.Decimal(8, 2)
  fundamentalsAt   DateTime? @map("fundamentals_at")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bhavcopy              BhavcopyDaily[]
  announcements         Announcement[]
  corporateActions      CorporateAction[]
  superInvestorHoldings SuperInvestorHolding[]

  @@index([sector])
  @@index([marketCap])
  @@index([peRatio])
  @@index([roePercent])
  @@map("companies")
}

// ============================================================
// Super Investor Holdings
// ============================================================

model SuperInvestorHolding {
  id           Int      @id @default(autoincrement())
  investorSlug String   @map("investor_slug")
  companyId    Int      @map("company_id")
  quarter      String   // "Q4FY25", "Q1FY26"
  pctHeld      Decimal  @map("pct_held") @db.Decimal(7, 3)
  sharesHeld   BigInt?  @map("shares_held")
  valueCr      Decimal? @map("value_cr") @db.Decimal(16, 2)
  qoqChange    String?  @map("qoq_change") // new|added|same|reduced|exited
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([investorSlug, companyId, quarter])
  @@index([investorSlug, quarter])
  @@index([companyId])
  @@map("super_investor_holdings")
}

// ============================================================
// IPO Module
// ============================================================

model Ipo {
  id              Int       @id @default(autoincrement())
  name            String
  slug            String    @unique
  type            String    // mainboard | sme
  priceBandLow    Decimal?  @map("price_band_low") @db.Decimal(12, 2)
  priceBandHigh   Decimal?  @map("price_band_high") @db.Decimal(12, 2)
  lotSize         Int?      @map("lot_size")
  issueSize       Decimal?  @map("issue_size") @db.Decimal(20, 2) // in crores
  issueSizeShares BigInt?   @map("issue_size_shares")
  openDate        DateTime? @map("open_date")
  closeDate       DateTime? @map("close_date")
  allotmentDate   DateTime? @map("allotment_date")
  listingDate     DateTime? @map("listing_date")
  registrar       String?
  registrarUrl    String?   @map("registrar_url")
  leadManagers    String?   @map("lead_managers")
  bseCode         String?   @map("bse_code")
  nseSymbol       String?   @map("nse_symbol")
  status          String    @default("upcoming") // upcoming | live | closed | listed | withdrawn
  faceValue       Decimal?  @map("face_value") @db.Decimal(8, 2)
  drhpUrl         String?   @map("drhp_url")
  rhpUrl          String?   @map("rhp_url")
  objectsOfIssue  String?   @map("objects_of_issue") @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions IpoSubscription[]
  gmpEntries    IpoGmp[]
  anchors       IpoAnchor[]
  listing       IpoListing?
  applications  IpoApplication[]
  reviews       IpoReview[]
  polls         IpoPoll[]
  drhpAnalysis  IpoDrhpAnalysis?

  @@index([status])
  @@index([type])
  @@index([openDate])
  @@map("ipos")
}

model IpoReview {
  id             Int      @id @default(autoincrement())
  ipoId          Int      @map("ipo_id")
  brokerHouse    String   @map("broker_house")
  recommendation String   // subscribe | avoid | neutral | subscribe_long | subscribe_listing
  rationale      String?  @db.Text
  targetPrice    Decimal? @map("target_price") @db.Decimal(12, 2)
  publishedAt    DateTime @map("published_at")
  source         String   @default("manual")
  sourceUrl      String?  @map("source_url") @db.Text
  createdAt      DateTime @default(now())

  ipo Ipo @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@index([ipoId])
  @@map("ipo_reviews")
}

model IpoSubscription {
  id         Int      @id @default(autoincrement())
  ipoId      Int      @map("ipo_id")
  capturedAt DateTime @map("captured_at")
  retailX    Decimal? @map("retail_x") @db.Decimal(10, 2)
  hniX       Decimal? @map("hni_x") @db.Decimal(10, 2)
  nii1X      Decimal? @map("nii_1_x") @db.Decimal(10, 2)   // NII > 10L
  nii2X      Decimal? @map("nii_2_x") @db.Decimal(10, 2)   // NII 2L-10L
  qibX       Decimal? @map("qib_x") @db.Decimal(10, 2)
  employeeX  Decimal? @map("employee_x") @db.Decimal(10, 2)
  totalX     Decimal? @map("total_x") @db.Decimal(10, 2)

  ipo Ipo @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@index([ipoId, capturedAt])
  @@map("ipo_subscription")
}

model IpoGmp {
  id              Int      @id @default(autoincrement())
  ipoId           Int      @map("ipo_id")
  date            DateTime @db.Date
  gmp             Decimal  @db.Decimal(10, 2)
  kostak          Decimal? @db.Decimal(10, 2)
  subjectToSauda  Decimal? @map("subject_to_sauda") @db.Decimal(10, 2)
  source          String?  // dealer name / "aggregated"
  notes           String?
  enteredBy       String?  @map("entered_by")
  createdAt       DateTime @default(now())

  ipo Ipo @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@unique([ipoId, date])
  @@index([date])
  @@map("ipo_gmp")
}

model IpoAnchor {
  id           Int      @id @default(autoincrement())
  ipoId        Int      @map("ipo_id")
  investorName String   @map("investor_name")
  allocation   BigInt?  // number of shares
  pricePerShare Decimal? @map("price_per_share") @db.Decimal(12, 2)
  value        Decimal? @db.Decimal(20, 2) // in crores
  lockIn30d    DateTime? @map("lock_in_30d")
  lockIn90d    DateTime? @map("lock_in_90d")

  ipo Ipo @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@index([ipoId])
  @@index([investorName])
  @@map("ipo_anchors")
}

model IpoListing {
  id               Int      @id @default(autoincrement())
  ipoId            Int      @unique @map("ipo_id")
  listingPrice     Decimal  @map("listing_price") @db.Decimal(12, 2)
  listingGainsPct  Decimal  @map("listing_gains_pct") @db.Decimal(8, 2)
  dayClose         Decimal? @map("day_close") @db.Decimal(12, 2)
  dayHigh          Decimal? @map("day_high") @db.Decimal(12, 2)
  dayLow           Decimal? @map("day_low") @db.Decimal(12, 2)
  gmpAtListing     Decimal? @map("gmp_at_listing") @db.Decimal(10, 2)
  gmpError         Decimal? @map("gmp_error") @db.Decimal(10, 2) // predicted - actual

  ipo Ipo @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@map("ipo_listings")
}

// ============================================================
// Corporate Actions + Announcements
// ============================================================

model CorporateAction {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  actionType  String    @map("action_type") // dividend | split | bonus | rights | buyback | agm | board_meeting
  exDate      DateTime? @map("ex_date") @db.Date
  recordDate  DateTime? @map("record_date") @db.Date
  bcStartDate DateTime? @map("bc_start_date") @db.Date
  bcEndDate   DateTime? @map("bc_end_date") @db.Date
  ratio       String?   // "1:2" for splits/bonus
  value       Decimal?  @db.Decimal(12, 2) // dividend amount etc.
  purpose     String?   @db.Text
  source      String    @default("bse") // bse | nse
  sourceId    String?   @map("source_id") // exchange's own ID for dedupe
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([source, sourceId])
  @@index([companyId, exDate])
  @@index([actionType, exDate])
  @@map("corporate_actions")
}

model Announcement {
  id           Int      @id @default(autoincrement())
  companyId    Int?     @map("company_id")
  bseCode      String?  @map("bse_code")
  nseSymbol    String?  @map("nse_symbol")
  headline     String   @db.Text
  category     String?
  subcategory  String?
  pdfUrl       String?  @map("pdf_url") @db.Text
  broadcastAt  DateTime @map("broadcast_at")
  source       String   @default("bse")
  sourceId     String?  @map("source_id")
  createdAt    DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@unique([source, sourceId])
  @@index([broadcastAt])
  @@index([companyId, broadcastAt])
  @@map("announcements")
}

// ============================================================
// FII / DII / FPI
// ============================================================

model FiiDiiDaily {
  id        Int      @id @default(autoincrement())
  date      DateTime @db.Date
  segment   String   // cash | fo_index_fut | fo_index_opt | fo_stock_fut | fo_stock_opt
  fiiBuy    Decimal? @map("fii_buy") @db.Decimal(20, 2)
  fiiSell   Decimal? @map("fii_sell") @db.Decimal(20, 2)
  fiiNet    Decimal? @map("fii_net") @db.Decimal(20, 2)
  diiBuy    Decimal? @map("dii_buy") @db.Decimal(20, 2)
  diiSell   Decimal? @map("dii_sell") @db.Decimal(20, 2)
  diiNet    Decimal? @map("dii_net") @db.Decimal(20, 2)
  createdAt DateTime @default(now())

  @@unique([date, segment])
  @@index([date])
  @@map("fii_dii_daily")
}

model FpiMonthly {
  id                   Int      @id @default(autoincrement())
  month                DateTime @db.Date // first of the month
  equityAuc            Decimal? @map("equity_auc") @db.Decimal(20, 2) // crores
  debtAuc              Decimal? @map("debt_auc") @db.Decimal(20, 2)
  hybridAuc            Decimal? @map("hybrid_auc") @db.Decimal(20, 2)
  sectorBreakdownJson  Json?    @map("sector_breakdown_json")
  createdAt            DateTime @default(now())

  @@unique([month])
  @@map("fpi_monthly")
}

// ============================================================
// Bhavcopy (EOD OHLC)
// ============================================================

model BhavcopyDaily {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  date        DateTime @db.Date
  open        Decimal  @db.Decimal(12, 2)
  high        Decimal  @db.Decimal(12, 2)
  low         Decimal  @db.Decimal(12, 2)
  close       Decimal  @db.Decimal(12, 2)
  volume      BigInt
  deliveryQty BigInt?  @map("delivery_qty")
  deliveryPct Decimal? @map("delivery_pct") @db.Decimal(6, 2)
  source      String   @default("bse") // bse | nse

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date, source])
  @@index([date])
  @@map("bhavcopy_daily")
}

// ============================================================
// Ingestion Logs
// ============================================================

model IngestionRun {
  id         Int      @id @default(autoincrement())
  jobName    String   @map("job_name")
  startedAt  DateTime @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  status     String   @default("running") // running | success | failed
  rowsIn     Int?     @map("rows_in")
  rowsError  Int?     @map("rows_error")
  errorMsg   String?  @map("error_msg") @db.Text
  notes      String?  @db.Text

  @@index([jobName, startedAt])
  @@map("ingestion_runs")
}

// ============================================================
// Newsletter / User Alerts
// ============================================================

// ============================================================
// AMFI Mutual Funds
// ============================================================

model MutualFund {
  id              Int      @id @default(autoincrement())
  schemeCode      String   @unique @map("scheme_code")
  isinGrowth      String?  @map("isin_growth")
  isinDivReinvest String?  @map("isin_div_reinvest")
  schemeName      String   @map("scheme_name")
  amc             String?
  category        String?
  nav             Decimal  @db.Decimal(14, 4)
  navAsOf         DateTime @map("nav_as_of") @db.Date
  slug            String   @unique
  active          Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([amc])
  @@map("mutual_funds")
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id")
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  ua        String?  @db.Text
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now()) @map("last_seen")

  @@index([userId])
  @@map("push_subs")
}

// ============================================================
// Auto-extracted DRHP / RHP intelligence (Round 28)
// ============================================================
// One row per IPO. Generated by `analyzeDrhp()` running over the prospectus
// PDF via Claude. Cached so every page view doesn't burn API tokens; only
// re-runs when sourceUrl changes or admin force-refreshes.

model IpoDrhpAnalysis {
  id                     Int      @id @default(autoincrement())
  ipoId                  Int      @unique @map("ipo_id")
  sourceUrl              String   @map("source_url") @db.Text
  sourceType             String   @map("source_type") // "DRHP" | "RHP"
  status                 String   @default("pending") // "pending" | "ready" | "failed" | "stale"
  generatedBy            String?  @map("generated_by") // model name e.g. "claude-sonnet-4-5"
  generatedAt            DateTime? @map("generated_at")
  errorMsg               String?  @map("error_msg") @db.Text

  // Structured fields — all JSON for flexibility, validated at the renderer
  tldr                   String?  @db.Text
  issueDetails           Json?    @map("issue_details")
  useOfProceeds          Json?    @map("use_of_proceeds")
  riskFactors            Json?    @map("risk_factors")
  governance             Json?
  relatedPartyTransactions Json?  @map("related_party_transactions")
  contingentLiabilities  Json?    @map("contingent_liabilities")
  peerComparables        Json?    @map("peer_comparables")
  enrichedPeers          Json?    @map("enriched_peers")
  financialHighlights    Json?    @map("financial_highlights")

  // Synthesized 0-100 risk score + breakdown (Round 29 vertical depth)
  riskScore              Int?     @map("risk_score")
  riskBand               String?  @map("risk_band") // "clean" | "watch" | "caution" | "high-risk"
  riskRationale          Json?    @map("risk_rationale")
  riskComponents         Json?    @map("risk_components")

  ipo Ipo @relation(fields: [ipoId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([generatedAt])
  @@index([riskScore])
  @@index([riskBand])
  @@map("ipo_drhp_analyses")
}

// ============================================================
// US Investing for Indians (Round 30)
// ============================================================

// ============================================================
// NSE / BSE Market Intelligence (Round 33)
// ============================================================

model BulkDeal {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  exchange    String   // NSE | BSE
  symbol      String
  companyName String   @map("company_name")
  clientName  String   @map("client_name")
  dealType    String   @map("deal_type") // BUY | SELL
  qty         BigInt
  price       Decimal  @db.Decimal(12, 2)
  valueCr     Decimal? @map("value_cr") @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  @@unique([date, exchange, symbol, clientName, dealType])
  @@index([date])
  @@index([symbol])
  @@index([clientName])
  @@map("bulk_deals")
}

model BlockDeal {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  exchange    String
  symbol      String
  companyName String   @map("company_name")
  clientName  String   @map("client_name")
  dealType    String   @map("deal_type")
  qty         BigInt
  price       Decimal  @db.Decimal(12, 2)
  valueCr     Decimal? @map("value_cr") @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  @@unique([date, exchange, symbol, clientName, dealType])
  @@index([date])
  @@index([symbol])
  @@map("block_deals")
}

model InsiderTrade {
  id              Int      @id @default(autoincrement())
  date            DateTime @db.Date
  exchange        String   // NSE | BSE
  symbol          String
  companyName     String   @map("company_name")
  acquirerName    String   @map("acquirer_name")
  acquirerType    String   @map("acquirer_type") // Promoter | Director | KMP | Other
  securityType    String   @map("security_type") // Equity | Options | etc
  tradeType       String   @map("trade_type") // Buy | Sell | Pledge | Revoke
  qty             BigInt?
  valueLakh       Decimal? @map("value_lakh") @db.Decimal(16, 2)
  preHoldingPct   Decimal? @map("pre_holding_pct") @db.Decimal(8, 4)
  postHoldingPct  Decimal? @map("post_holding_pct") @db.Decimal(8, 4)
  disclosureDate  DateTime? @map("disclosure_date") @db.Date
  createdAt       DateTime @default(now())

  @@unique([date, exchange, symbol, acquirerName, tradeType, qty])
  @@index([date])
  @@index([symbol])
  @@index([acquirerName])
  @@map("insider_trades")
}

model UsIpo {
  id              Int      @id @default(autoincrement())
  symbol          String?  @unique
  companyName     String   @map("company_name")
  slug            String   @unique
  exchange        String?  // NYSE | NASDAQ | NYSE American
  filedDate       DateTime? @map("filed_date") @db.Date
  expectedDate    DateTime? @map("expected_date") @db.Date
  priceLow        Decimal?  @map("price_low") @db.Decimal(10, 2)
  priceHigh       Decimal?  @map("price_high") @db.Decimal(10, 2)
  sizeUsdMn       Decimal?  @map("size_usd_mn") @db.Decimal(14, 2)
  sector          String?
  description     String?   @db.Text
  s1Url           String?   @map("s1_url") @db.Text
  status          String    @default("upcoming") // upcoming | priced | trading | withdrawn
  listingPriceUsd Decimal?  @map("listing_price_usd") @db.Decimal(10, 2)
  currentPriceUsd Decimal?  @map("current_price_usd") @db.Decimal(10, 2)
  listingGainPct  Decimal?  @map("listing_gain_pct") @db.Decimal(8, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([expectedDate])
  @@map("us_ipos")
}

model UsAdrlisting {
  id              Int      @id @default(autoincrement())
  companyName     String   @map("company_name")
  slug            String   @unique
  nseSymbol       String?  @map("nse_symbol")
  bseCode         String?  @map("bse_code")
  adrSymbol       String   @map("adr_symbol")
  exchange        String?  // NYSE | NASDAQ
  ratio           String?  // e.g. "1 ADR = 2 NSE shares"
  nsePrice        Decimal? @map("nse_price") @db.Decimal(12, 2)
  adrPriceUsd     Decimal? @map("adr_price_usd") @db.Decimal(10, 2)
  premiumPct      Decimal? @map("premium_pct") @db.Decimal(8, 2)
  usdInrRate      Decimal? @map("usd_inr_rate") @db.Decimal(8, 4)
  pricesAt        DateTime? @map("prices_at")
  sector          String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([adrSymbol])
  @@map("us_adr_listings")
}

// ============================================================
// Nifty Index Daily Data (from NSE archives ind_close_all_DDMMYYYY.csv)
// Contains P/E, P/B, Div Yield for 70+ indices
// ============================================================
model NiftyIndex {
  id          Int      @id @default(autoincrement())
  indexName   String   @map("index_name")
  date        DateTime @db.Date
  open        Decimal  @db.Decimal(14, 2)
  high        Decimal  @db.Decimal(14, 2)
  low         Decimal  @db.Decimal(14, 2)
  close       Decimal  @db.Decimal(14, 2)
  pointsChg   Decimal? @map("points_chg") @db.Decimal(10, 2)
  changePct   Decimal? @map("change_pct") @db.Decimal(8, 4)
  volume      BigInt?
  turnoverCr  Decimal? @map("turnover_cr") @db.Decimal(16, 2)
  pe          Decimal? @db.Decimal(8, 2)
  pb          Decimal? @db.Decimal(8, 2)
  divYield    Decimal? @map("div_yield") @db.Decimal(6, 2)
  createdAt   DateTime @default(now())

  @@unique([indexName, date])
  @@index([date])
  @@index([indexName])
  @@map("nifty_indices")
}

model MarketSummary {
  id          Int      @id @default(autoincrement())
  date        DateTime @unique  // one row per trading day
  headline    String   @db.Text
  body        String   @db.Text
  sentiment   String?  // "bullish" | "neutral" | "bearish"
  fiiNet      Decimal? @map("fii_net") @db.Decimal(14, 2)
  diiNet      Decimal? @map("dii_net") @db.Decimal(14, 2)
  topGainers  Json?    @map("top_gainers")
  topLosers   Json?    @map("top_losers")
  generatedBy String?  @map("generated_by") // "claude-sonnet-4-5"
  createdAt   DateTime @default(now())

  @@index([date])
  @@map("market_summaries")
}

// ============================================================
// Next-Day Market Preview (AI-generated at 8 PM IST)
// ============================================================
model NextDayPreview {
  id            Int      @id @default(autoincrement())
  forDate       DateTime @unique @map("for_date") @db.Date // the trading day this covers (tomorrow)
  headline      String   @db.Text                          // e.g. "Watch IT + HDFC Bank; FII net sellers"
  body          String   @db.Text                          // 150-word AI narrative
  sentiment     String?                                    // "cautious" | "neutral" | "positive"
  stocksToWatch Json?    @map("stocks_to_watch")           // [{symbol, name, reason, level}]
  sectorFocus   String?  @map("sector_focus")              // "IT" | "Banking" etc.
  keyEvents     Json?    @map("key_events")                // [{type, desc, date}] — IPO opens, ex-dates, etc.
  fiiSignal     String?  @map("fii_signal")                // "buy" | "sell" | "neutral"
  fiiNet        Decimal? @map("fii_net") @db.Decimal(14, 2)
  diiNet        Decimal? @map("dii_net") @db.Decimal(14, 2)
  generatedBy   String?  @map("generated_by")
  createdAt     DateTime @default(now())

  @@index([forDate])
  @@map("next_day_previews")
}

model NewsletterSub {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  verified    Boolean  @default(false)
  preferences Json?
  createdAt   DateTime @default(now())

  @@map("newsletter_subs")
}

// ============================================================
// Advisor / Referral program (gated by advisor.enabled flag)
// ============================================================

model Advisor {
  id                Int      @id @default(autoincrement())
  userId            String   @unique @map("user_id")
  refCode           String   @unique @map("ref_code")
  status            String   @default("pending")
  fullName          String?  @map("full_name")
  phone             String?
  city              String?
  experience        String?  @db.Text
  commissionPercent Decimal  @default(50) @map("commission_percent") @db.Decimal(5, 2)
  upiId             String?  @map("upi_id")
  bankAccount       String?  @map("bank_account")
  ifsc              String?
  totalEarnedInr    Decimal  @default(0) @map("total_earned_inr") @db.Decimal(14, 2)
  totalPaidInr      Decimal  @default(0) @map("total_paid_inr") @db.Decimal(14, 2)
  approvedAt        DateTime? @map("approved_at")
  notes             String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  clicks      AdvisorClick[]
  commissions AdvisorCommission[]
  payouts     AdvisorPayout[]

  @@index([status])
  @@map("advisors")
}

model AdvisorClick {
  id              Int      @id @default(autoincrement())
  advisorId       Int      @map("advisor_id")
  productSlug     String   @map("product_slug")
  productCategory String?  @map("product_category")
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent") @db.Text
  createdAt       DateTime @default(now())

  advisor Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, createdAt])
  @@index([productSlug])
  @@map("advisor_clicks")
}

model AdvisorCommission {
  id                   Int      @id @default(autoincrement())
  advisorId            Int      @map("advisor_id")
  productSlug          String   @map("product_slug")
  productCategory      String?  @map("product_category")
  partnerCommissionInr Decimal  @map("partner_commission_inr") @db.Decimal(12, 2)
  advisorShareInr      Decimal  @map("advisor_share_inr") @db.Decimal(12, 2)
  status               String   @default("pending")
  notes                String?  @db.Text
  createdAt            DateTime @default(now())

  advisor Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, status])
  @@map("advisor_commissions")
}

model AdvisorPayout {
  id        Int      @id @default(autoincrement())
  advisorId Int      @map("advisor_id")
  amountInr Decimal  @map("amount_inr") @db.Decimal(12, 2)
  mode      String?
  txnRef    String?  @map("txn_ref")
  paidAt    DateTime @default(now()) @map("paid_at")
  notes     String?

  advisor Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)

  @@index([advisorId, paidAt])
  @@map("advisor_payouts")
}

model FeatureFlag {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  enabled     Boolean  @default(true)
  label       String
  description String?  @db.Text
  category    String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?  @map("updated_by")

  @@map("feature_flags")
}

// Key-value store for admin settings (Kite token, etc.)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}
